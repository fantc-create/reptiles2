<!DOCTYPE html>
<html lang="zh-HK">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>動物/植物日常護理表與紀錄系統</title>
    <style>
        :root {
            --primary-color: #4A90E2;
            --success-color: #2ecc71;
            --danger-color: #e74c3c;
            --border-color: #ddd;
            --bg-color: #f5f7fa;
            --text-color: #333;
        }

        body {
            font-family: "Microsoft JhengHei", "PingFang HK", sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            margin: 0;
            padding: 15px;
        }

        /* 導覽列(分頁按鈕)樣式 */
        .nav-tabs {
            max-width: 1200px;
            margin: 0 auto 20px auto;
            display: flex;
            justify-content: center;
            gap: 10px;
        }

        .tab-btn {
            flex: 1;
            max-width: 200px;
            background-color: #e0e0e0;
            color: #555;
            padding: 12px 10px;
            font-size: 1em;
            border: none;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s ease;
            text-align: center;
        }

        .tab-btn.active {
            background-color: var(--primary-color);
            color: white;
            box-shadow: 0 4px 10px rgba(74, 144, 226, 0.3);
        }

        /* 區塊隱藏與顯示 */
        .section-container {
            display: none;
            max-width: 1200px;
            margin: 0 auto;
            background-color: #fff;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
            animation: fadeIn 0.3s ease-in-out;
        }

        .section-container.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(5px); }
            to { opacity: 1; transform: translateY(0); }
        }

        h2, h3 { text-align: center; color: var(--text-color); margin-top: 0; }

        /* 輸入區塊排版 */
        .header-info {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            margin-bottom: 25px;
            font-size: 1.1em;
            background-color: #f9fbfd;
            padding: 15px;
            border-radius: 8px;
            border: 1px solid #e1e8ed;
        }

        .input-group {
            display: flex;
            align-items: center;
            gap: 10px;
            flex: 1;
            min-width: 250px;
        }

        .input-group input[type="text"], 
        .input-group input[type="date"] {
            flex: 1;
            border: 1px solid var(--border-color);
            border-radius: 5px;
            padding: 8px 10px;
            font-size: 1em;
            outline: none;
            transition: border-color 0.3s;
        }

        .input-group input:focus { border-color: var(--primary-color); }

        /* 電腦版表格樣式 */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
            background: #fff;
        }

        th, td {
            text-align: left;
            padding: 15px;
            border: 1px solid var(--border-color);
            vertical-align: top;
        }

        th { background-color: #f8f9fa; font-weight: bold; color: #555; white-space: nowrap; text-align: center; }
        
        /* 元件設計 */
        .checkbox-label {
            display: flex;
            align-items: center;
            margin-bottom: 10px;
            cursor: pointer;
            user-select: none;
            padding: 5px 0;
        }

        .feed-item {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            margin-bottom: 10px;
            gap: 10px;
        }

        .feed-item .checkbox-label { margin-bottom: 0; }

        .qty-input {
            width: 70px;
            padding: 6px 8px;
            border: 1px solid var(--border-color);
            border-radius: 4px;
            font-size: 1em;
            outline: none;
        }

        .checkbox-label input[type="checkbox"] {
            margin-right: 10px;
            width: 22px;
            height: 22px;
            accent-color: var(--primary-color);
        }

        .na-text { color: #aaa; font-style: italic; text-align: center; }
        .animal-name { font-weight: bold; font-size: 1.1em; text-align: center; background-color: #f0f4f8; }

        /* 按鈕區塊 */
        .actions {
            margin-top: 30px;
            display: flex;
            justify-content: center;
            gap: 15px;
            flex-wrap: wrap;
        }

        button {
            padding: 12px 25px;
            font-size: 1.1em;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.2s;
            flex: 1;
            max-width: 250px;
        }

        button:active { transform: scale(0.98); }
        .btn-save { background-color: var(--success-color); color: white; }
        .btn-reset { background-color: #e0e0e0; color: #333; }
        .btn-export { background-color: #217346; color: white; }

        .btn-delete { background-color: var(--danger-color); color: white; padding: 6px 12px; font-size: 0.9em; flex: none; }

        /* 手機版響應式設計：將表格轉為卡片 */
        @media (max-width: 768px) {
            .section-container { padding: 15px; }
            .header-info { flex-direction: column; gap: 15px; }
            
            table, thead, tbody, th, td, tr { display: block; width: 100%; box-sizing: border-box; }
            thead { display: none; } 
            
            tr { 
                border: 2px solid var(--primary-color); 
                border-radius: 12px; 
                margin-bottom: 20px; 
                overflow: hidden; 
                box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            }
            
            td.animal-name { 
                background-color: var(--primary-color); 
                color: white; 
                font-size: 1.3em; 
                padding: 12px; 
                text-align: center; 
            }
            
            td { 
                border: none; 
                border-bottom: 1px solid #eee; 
                padding: 15px; 
                position: relative; 
            }
            
            td:last-child { border-bottom: none; }
            
            td:not(.animal-name)::before { 
                content: attr(data-label); 
                font-weight: bold; 
                color: var(--primary-color); 
                display: block; 
                margin-bottom: 8px; 
                font-size: 0.9em;
                border-bottom: 2px dashed #eee;
                padding-bottom: 5px;
            }
            
            .na-text { text-align: left; color: #999; }
        }

        .record-item-details { line-height: 1.8; margin-top: 5px; }
        .empty-msg { text-align: center; color: #999; padding: 40px 20px; }
    </style>
</head>
<body>

