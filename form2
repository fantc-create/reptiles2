        <table style="min-width: 600px;">
            <thead>
                <tr>
                    <th style="width: 15%;">日期</th>
                    <th style="width: 15%;">負責學生</th>
                    <th style="width: 60%;">完成項目</th>
                    <th style="width: 10%;">操作</th>
                </tr>
            </thead>
            <tbody id="recordList">
            </tbody>
        </table>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        setToday();
        loadRecords();
    });

    function switchTab(tabId) {
        document.getElementById('btn-form').classList.remove('active');
        document.getElementById('btn-history').classList.remove('active');
        document.getElementById('formSection').classList.remove('active');
        document.getElementById('historySection').classList.remove('active');

        if (tabId === 'form') {
            document.getElementById('btn-form').classList.add('active');
            document.getElementById('formSection').classList.add('active');
        } else if (tabId === 'history') {
            document.getElementById('btn-history').classList.add('active');
            document.getElementById('historySection').classList.add('active');
            loadRecords();
        }
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function setToday() {
        const today = new Date().toISOString().split('T')[0];
        document.getElementById('recordDate').value = today;
    }

    function loadRecords() {
        const records = JSON.parse(localStorage.getItem('careRecords_uncombined')) || [];
        const recordList = document.getElementById('recordList');
        recordList.innerHTML = ''; 

        if (records.length === 0) {
            recordList.innerHTML = '<tr><td colspan="4" class="empty-msg">目前尚未有任何護理紀錄</td></tr>';
            return;
        }

        records.slice().reverse().forEach((record, index) => {
            const originalIndex = records.length - 1 - index; 
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td>${record.date}</td>
                <td><strong>${record.studentName}</strong></td>
                <td><div class="record-item-details">${record.details}</div></td>
                <td style="text-align:center;"><button class="btn-delete" onclick="deleteRecord(${originalIndex})">刪除</button></td>
            `;
            recordList.appendChild(tr);
        });
    }

    function saveData() {
        const studentName = document.getElementById('studentName').value.trim();
        const date = document.getElementById('recordDate').value;
        
        if (!studentName || !date) {
            alert('請填寫「負責學生姓名」與「日期」！');
            return;
        }

        const rows = document.querySelectorAll('#careTable tbody tr');
        let completedItems = [];

        rows.forEach(row => {
            const rawAnimalName = row.querySelector('.animal-name').innerText;
            const animalName = rawAnimalName.replace(/[\uD800-\uDBFF][\uDC00-\uDFFF]\s*/g, '').trim(); 
            
            const checkedBoxes = row.querySelectorAll('input[type="checkbox"]:checked');
            
            if (checkedBoxes.length > 0) {
                let actions = Array.from(checkedBoxes).map(cb => {
                    let actionText = cb.value;
                    if (cb.classList.contains('feed-checkbox')) {
                        const wrapper = cb.closest('.feed-item');
                        const qtyInput = wrapper.querySelector('.qty-input');
                        if (qtyInput && qtyInput.value.trim() !== '') {
                            actionText += ` (數量: ${qtyInput.value})`;
                        }
                    }
                    return actionText;
                });
                completedItems.push(`<strong>【${animalName}】</strong><br>${actions.join('、')}`);
            }
        });

        if (completedItems.length === 0) {
            alert('請至少勾選一項完成的護理任務！');
            return;
        }

        const newRecord = {
            studentName: studentName,
            date: date,
            details: completedItems.join('<br><br>') 
        };

        const records = JSON.parse(localStorage.getItem('careRecords_uncombined')) || [];
        records.push(newRecord);
        localStorage.setItem('careRecords_uncombined', JSON.stringify(records));

        alert('✅ 紀錄已成功儲存！');
        resetForm(false);
        switchTab('history');
    }

    function deleteRecord(index) {
        if (confirm('確定要刪除這筆紀錄嗎？')) {
            let records = JSON.parse(localStorage.getItem('careRecords_uncombined')) || [];
            records.splice(index, 1); 
            localStorage.setItem('careRecords_uncombined', JSON.stringify(records));
            loadRecords(); 
        }
    }

    function resetForm(showConfirm) {
        if (!showConfirm || confirm('確定要清除畫面上所有已填寫的資料嗎？')) {
            document.getElementById('studentName').value = '';
            setToday();
            
            document.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = false);
            document.querySelectorAll('.qty-input').forEach(input => input.value = '');
        }
    }

    function exportToExcel() {
        const records = JSON.parse(localStorage.getItem('careRecords_uncombined')) || [];
        
        if (records.length === 0) {
            alert('目前沒有任何紀錄可以匯出！');
            return;
        }

        let csvContent = '\uFEFF'; 
        csvContent += '日期,負責學生,完成項目\n';

        records.forEach(record => {
            let textDetails = record.details
                .replace(/<br><br>/g, ' \n ') 
                .replace(/<br>/g, ' / ')
                .replace(/<strong>/g, '')
                .replace(/<\/strong>/g, '');
            
            let safeName = `"${record.studentName}"`;
            let safeDetails = `"${textDetails}"`;
            
            csvContent += `${record.date},${safeName},${safeDetails}\n`;
        });

        const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
        const link = document.createElement("a");
        const url = URL.createObjectURL(blob);
        
        link.setAttribute("href", url);
        link.setAttribute("download", `動物護理紀錄_${new Date().toISOString().split('T')[0]}.csv`);
        link.style.visibility = 'hidden';
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    }
</script>

</body>
</html>
